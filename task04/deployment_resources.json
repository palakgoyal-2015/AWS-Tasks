{
  "lambda-basic-execution": {
    "policy_content": {
      "Statement": [
        {
          "Action": [
            "logs:CreateLogGroup",
            "logs:CreateLogStream",
            "logs:PutLogEvents"
          ],
          "Effect": "Allow",
          "Resource": "*"
        }
      ],
      "Version": "2012-10-17"
    },
    "resource_type": "iam_policy",
    "tags": {}
  },
  "sqs_queue_policy": {
    "policy_content": {
      "Statement": [
        {
          "Action": [
            "sqs:ReceiveMessage",
            "sqs:DeleteMessage",
            "sqs:GetQueueAttributes",
            "sqs:ChangeMessageVisibility"
          ],
          "Effect": "Allow",
          "Resource": "*"
        }
      ],
      "Version": "2012-10-17"
    },
    "resource_type": "iam_policy",
    "tags": {}
  },
  "sns_topic_policy": {
    "policy_content": {
      "Statement": [
        {
          "Action": [
            "sns:GetTopicAttributes",
            "sns:Subscribe"
          ],
          "Effect": "Allow",
          "Resource": "*"
        }
      ],
      "Version": "2012-10-17"
    },
    "resource_type": "iam_policy",
    "tags": {}
  },
  "sqs_handler-role": {
    "predefined_policies": [],
    "principal_service": "lambda",
    "custom_policies": [
      "lambda-basic-execution",
      "sqs_queue_policy"
    ],
    "resource_type": "iam_role",
    "tags": {}
  },
  "sns_handler-role": {
    "predefined_policies": [],
    "principal_service": "lambda",
    "custom_policies": [
      "lambda-basic-execution",
      "sns_topic_policy"
    ],
    "resource_type": "iam_role",
    "tags": {}
  },
  "async_queue": {
    "resource_type": "sqs_queue",
    "visibility_timeout": 300,
    "tags": {}
  },
  "lambda_topic": {
    "resource_type": "sns_topic",
    "tags": {}
  }
}